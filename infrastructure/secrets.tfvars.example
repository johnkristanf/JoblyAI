# Example: copy to secrets.tfvars and fill in real values
# NEVER commit secrets.tfvars to version control

region      = "ap-southeast-1"
profile     = "your-aws-profile"
environment = "production"

db_name     = "joblyai"
db_username = "joblyai_admin"
db_password = "CHANGE_ME_use_a_strong_password"
